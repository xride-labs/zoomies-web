# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:5000/api"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match NEXT_PUBLIC_APP_URL
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-strong-random-secret"

# ─── Launch Gate ──────────────────────────────────────────────────────────────
# Set WEB_DISABLED=true to show /launch page instead of the app
WEB_DISABLED="false"
NEXT_PUBLIC_WEB_DISABLED="false"
NEXT_PUBLIC_LAUNCH_DATE="2026-08-31T18:30:00.000Z"
# Google Form embed URL shown on /launch page
NEXT_PUBLIC_GOOGLE_FORM_EMBED_URL="https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform?embedded=true"
# Google Sheet linked to the form — shown in /admin/launch-interest
GOOGLE_FORM_RESPONSES_URL="https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit?usp=sharing"
# Optional webhook POSTed when someone submits the interest form
INTEREST_WEBHOOK_URL=""

# ─── Optional: Monitoring ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GRAFANA_URL="http://localhost:3001"
# NEXT_PUBLIC_PROMETHEUS_URL="http://localhost:9090"

# ─── Sentry (Frontend) ───────────────────────────────────────────────────────
# Public DSN for browser events
NEXT_PUBLIC_SENTRY_DSN=""
# Optional client env overrides
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1.0"
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0.05"
# Optional server/edge DSN (can be same as public)
SENTRY_DSN=""
# Optional server/edge overrides
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# Used during build for source map upload
SENTRY_AUTH_TOKEN=""
# Organization + project for build-time uploads
NEXT_PUBLIC_SENTRY_ORG=""
NEXT_PUBLIC_SENTRY_PROJECT=""
