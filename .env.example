# App
NEXT_PUBLIC_APP_URL="your-app-url-here" # e.g. http://localhost:3000 or https://zoomies.xride-labs.in

# Launch-mode gate (set true to disable app routes and show /launch only)
NEXT_PUBLIC_WEB_DISABLED="true" # set to "true" to disable main app and show launch page, or "false" to enable app routes
# Countdown target for /launch page
NEXT_PUBLIC_LAUNCH_DATE="2026-08-31T18:30:00.000Z"
# Public Google Form embedded on /launch
NEXT_PUBLIC_GOOGLE_FORM_EMBED_URL="https://docs.google.com/forms/d/e/1FAIpQLSfyvoEvxmRfF9_S6Yd-8CYgXPKlVlFxq4dptlXorZU-lhxIGg/viewform?embedded=true"
# Admin responses URL embedded on /admin/launch-interest (linked sheet or analytics page)
GOOGLE_FORM_RESPONSES_URL="https://docs.google.com/spreadsheets/d/1muLEAb7zU2lau67ojScSnT5Aop7_re6ftzcd_HACQbM/edit?usp=sharing"

# Backend API
NEXT_PUBLIC_API_URL="your-api-url-here" # e.g. http://localhost:5000/api or https://api.zoomies.xride-labs.in/api

# Monitoring Services
NEXT_PUBLIC_GRAFANA_URL="your-grafana-url-here" # e.g. http://localhost:3001 or https://grafana.zoomies.xride-labs.in
NEXT_PUBLIC_PROMETHEUS_URL="your-prometheus-url-here" # e.g. http://localhost:9090 or https://prometheus.zoomies.xride-labs.in

# NextAuth
NEXTAUTH_URL="your-nextauth-url-here" # e.g. http://localhost:3000 or https://zoomies.xride-labs.in
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Note: Google OAuth credentials are configured in zoomies-backend
# with AUTH_GOOGLE_ID and AUTH_GOOGLE_SECRET.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY is currently not used in zoomies-web.
